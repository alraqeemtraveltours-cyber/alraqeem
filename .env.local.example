# Supabase connection — copy this file to `.env.local` and fill in real values.
# Find these in Supabase: Dashboard → Project Settings → API.

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser; used for public reads).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key (SECRET — server only, never commit, never expose).
# Used by the /admin write APIs to add and delete content.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Admin dashboard auth (REQUIRED for /admin to work)
# ---------------------------------------------------------------------------
# Passcode entered on the /admin login screen. There is NO default — login
# fails until this is set.
ADMIN_PASSCODE=

# Random secret used to sign admin session cookies. Generate with:
#   openssl rand -base64 32
# Rotating it logs every admin out.
ADMIN_SESSION_SECRET=

# ---------------------------------------------------------------------------
# Contact-form email (inquiries). Without these the form still SAVES the lead
# to the `inquiries` table, but no notification email is sent.
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
INQUIRY_TO_EMAIL=alraqeemtraveltours@gmail.com
INQUIRY_FROM_EMAIL=info@alraqeem.com.pk
INQUIRY_FROM_NAME=Al Raqeem Travel & Tours

# ---------------------------------------------------------------------------
# Optional: secret required by the Vercel keep-alive cron (/api/cron/keep-alive).
# When set, the endpoint rejects calls without a matching Bearer token.
# ---------------------------------------------------------------------------
CRON_SECRET=
